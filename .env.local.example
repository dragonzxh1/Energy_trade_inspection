# OpenSanctions API (commercial license required for SaaS use)
OPENSANCTIONS_API_KEY=your_key_here

# UK Companies House API (free, register at https://developer.companieshouse.gov.uk)
COMPANIES_HOUSE_API_KEY=your_key_here

# Database (Docker Postgres)
DATABASE_URL=postgresql://eti:eti_password@localhost:5432/energy_trade_inspection

# Stripe (Phase 1 payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET=replace_with_long_random_secret
SYNC_SECRET=replace_with_long_random_secret

# Dify / internal content pipeline
DIFY_BASE_URL=http://127.0.0.1
DIFY_API_KEY=app-...
DIFY_WORKFLOW_API_KEY=app-...
DIFY_WORKFLOW_USER=telegram-ingest
DIFY_WORKFLOW_RESPONSE_MODE=blocking
DIFY_WORKFLOW_FILE_TYPE=document
ETI_INGEST_ENDPOINT=http://localhost:3000/api/internal/content/ingest
ETI_ADMIN_BEARER=replace_with_admin_secret

# Telegram personal-account collector
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=telegram_api_hash
TELEGRAM_SOURCE_CHAT=@your_source_chat
TELEGRAM_SESSION_FILE=tmp/telegram/eti_telegram
TELEGRAM_DOWNLOAD_DIR=tmp/telegram/raw
TELEGRAM_STATE_FILE=tmp/telegram/state.json
TELEGRAM_POLL_LIMIT=100
TELEGRAM_POLL_INTERVAL=120

# Email (Resend) — required for email/password auth
RESEND_API_KEY=re_...
FROM_EMAIL=ETI <noreply@yourdomain.com>
