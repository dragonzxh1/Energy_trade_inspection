# OpenSanctions API (commercial license required for SaaS use)
OPENSANCTIONS_API_KEY=your_key_here

# UK Companies House API (free, register at https://developer.companieshouse.gov.uk)
COMPANIES_HOUSE_API_KEY=your_key_here

# Database (Docker Postgres)
DATABASE_URL=postgresql://eti:eti_password@localhost:5432/energy_trade_inspection

# Stripe (Phase 1 payments)
STRIPE_SECRET_KEY=sk_test_...
