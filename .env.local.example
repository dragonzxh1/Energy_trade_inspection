NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) — required for email/password auth
RESEND_API_KEY=re_...
FROM_EMAIL=ETI <noreply@yourdomain.com>
